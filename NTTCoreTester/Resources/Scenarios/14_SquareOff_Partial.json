{
  "testName": "Partial Square-Off - Single Symbol",
  "description": "Square off partial quantity of an open MIS position on NSE equity, validate position reduction and proportional margin release.",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "GetSecurityInfo",
      "activity": "ExtractSecurityInfo",
      "payload": {
        "exch": "NSE",
        "token": "10604"
      }
    },
    {
      "endpoint": "Limits",
      "activity": "ExtractPreLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },
    {
      "endpoint": "GetOrderMargin",
      "activity": "ExtractGetOrderMargin",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "NSE",
        "tsym": "{{tsym}}",
        "qty": "50",
        "trantype": "Sell",
        "ordno": "0",
        "prc": 0,
        "trgprc": "0",
        "dscqty": "0",
        "prd": "MIS",
        "prctyp": "Limit",
        "ordersource": "Web",
        "blprc": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0",
        "snonum": "0"
      }
    },
    {
      "endpoint": "PositionBook",
      "activity": "ExtractPrePositions",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}",
        "prd": ""
      }
    },
    {
      "endpoint": "PlaceOrder",
      "description": "Partial sell to reduce open long MIS position.",
      "activity": "ExtractClientOrdId",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "trantype": "Sell",
        "norenordno": "0",
        "segment": "EQ",
        "tsym": "{{tsym}}",
        "qty": 50,
        "prc": "0.00",
        "trgprc": "0",
        "dscqty": 0,
        "prd": "MIS",
        "prctyp": "MKT",
        "mkt_protection": "0",
        "ret": "DAY",
        "remarks": "",
        "ordersource": "Web",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ext_remarks": "External remarks",
        "cl_ord_id": "",
        "tsym2": "",
        "trantype2": "",
        "qty2": "0",
        "prc2": "0",
        "tsym3": "0",
        "trantype3": "",
        "qty3": "0",
        "prc3": "0",
        "algo_id": "0",
        "naic_code": "0",
        "snonum": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0"
      }
    },
    {
      "endpoint": "OrderBook",
      "activity": "SaveOrders",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}"
      }
    },
    {
      "endpoint": "ActivityOrderBook",
      "activity": "ValidateOrderBookSync",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },
    {
      "endpoint": "ActivityOrderBook",
      "activity": "OrderStatusHandler",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },
    {
      "endpoint": "TradeBook",
      "activity": "ExtractTradeFill",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}",
        "prd": ""
      }
    },
    {
      "endpoint": "PositionBook",
      "activity": "ValidatePostPositions",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}",
        "prd": ""
      }
    },
    {
      "endpoint": "Limits",
      "activity": "ExtractPostLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    }
  ]
}