{
  "testName": "Order Modification - Increase Quantity",
  "description": "Place pending CNC limit order, modify to increase qty. Validate additional margin blocked. Cancel after to release margin.",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "GetSecurityInfo",
      "activity": "ExtractSecurityInfo",
      "payload": {
        "exch": "NSE",
        "token": "2885"
      }
    },
    {
      "endpoint": "Limits",
      "activity": "ExtractPreLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },
    {
      "endpoint": "GetOrderMargin",
      "activity": "ExtractGetOrderMargin",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "NSE",
        "tsym": "{{tsym}}",
        "qty": "100",
        "trantype": "Buy",
        "ordno": "0",
        "prc": 5,
        "trgprc": "0",
        "dscqty": "0",
        "prd": "CNC",
        "prctyp": "Limit",
        "ordersource": "Web",
        "blprc": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0",
        "snonum": "0"
      }
    },
    {
      "endpoint": "PlaceOrder",
      "description": "Place CNC Buy Limit at low price to keep pending.",
      "activity": "ExtractClientOrdId",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "trantype": "Buy",
        "norenordno": "0",
        "segment": "EQ",
        "tsym": "{{tsym}}",
        "qty": 100,
        "prc": "5.00",
        "trgprc": "0",
        "dscqty": 0,
        "prd": "CNC",
        "prctyp": "Limit",
        "mkt_protection": "0",
        "ret": "DAY",
        "remarks": "",
        "ordersource": "Web",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ext_remarks": "External remarks",
        "cl_ord_id": "",
        "tsym2": "",
        "trantype2": "",
        "qty2": "0",
        "prc2": "0",
        "tsym3": "0",
        "trantype3": "",
        "qty3": "0",
        "prc3": "0",
        "algo_id": "0",
        "naic_code": "0",
        "snonum": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0"
      }
    },
    {
      "endpoint": "OrderBook",
      "activity": "SaveOrders",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}"
      }
    },
    {
      "endpoint": "ActivityOrderBook",
      "description": "Confirm order is PENDING before modification.",
      "activity": "OrderStatusHandler",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },
    {
      "endpoint": "Limits",
      "description": "Capture margin after initial pending order (100 qty blocked).",
      "activity": "ExtractPostLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },
    {
      "endpoint": "ModifyOrder",
      "description": "Increase quantity from 100 to 200.",
      "activity": "ExtractClientOrdId",
      "payload": {
        "exch": "{{exch}}",
        "ordno": "{{ordno}}",
        "prctyp": "Limit",
        "prc": "5.00",
        "qty": 200,
        "tsym": "{{tsym}}",
        "ret": "DAY",
        "mkt_protection": "0",
        "trgprc": "0.00",
        "dscqty": 0,
        "ext_remarks": "",
        "cl_ord_id": "{{cl_ord_id}}",
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ordersource": "Web",
        "orderactivity": 1,
        "prd": "CNC",
        "tqty": 200
      }
    },
    {
      "endpoint": "ActivityOrderBook",
      "description": "Confirm modified order still PENDING with qty 200.",
      "activity": "OrderStatusHandler",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },
    {
      "endpoint": "Limits",
      "description": "Validate additional margin blocked after qty increase.",
      "activity": "ExtractPostLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },
    {
      "endpoint": "CancelOrder",
      "description": "Cancel modified pending order to release margin.",
      "activity": "",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "cl_ord_id": "{{cl_ord_id}}",
        "ordno": "{{cl_ord_id}}",
        "ext_remarks": "cleanup"
      }
    },
    {
      "endpoint": "Limits",
      "description": "Validate full margin released after cancellation.",
      "activity": "ExtractPostLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    }
  ]
}