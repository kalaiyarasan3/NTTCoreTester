{
  "testName": "Hedge Create - Long Future + Short Call NFO",
  "description": "Buy NFO futures (CNC) and sell a call option (MIS) on same underlying. Validate reduced hedge margin vs standalone margin.",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "GetSecurityInfo",
      "description": "Extract NFO futures leg security info.",
      "activity": "ExtractSecurityInfo",
      "payload": {
        "exch": "NFO",
        "token": "35004"
      }
    },
    {
      "endpoint": "Limits",
      "activity": "ExtractPreLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },
    {
      "endpoint": "GetOrderMargin",
      "description": "Fetch margin for futures buy leg.",
      "activity": "ExtractGetOrderMargin",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "NFO",
        "tsym": "{{tsym}}",
        "qty": "{{lotsize}}",
        "trantype": "Buy",
        "ordno": "0",
        "prc": 0,
        "trgprc": "0",
        "dscqty": "0",
        "prd": "CNC",
        "prctyp": "Limit",
        "ordersource": "Web",
        "blprc": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0",
        "snonum": "0"
      }
    },
    {
      "endpoint": "PositionBook",
      "activity": "ExtractPrePositions",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}",
        "prd": ""
      }
    },
    {
      "endpoint": "PlaceOrder",
      "description": "Place CNC Buy for futures leg.",
      "activity": "ExtractClientOrdId",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "NFO",
        "trantype": "Buy",
        "norenordno": "0",
        "segment": "DER",
        "tsym": "{{tsym}}",
        "qty": "{{lotsize}}",
        "prc": "0.00",
        "trgprc": "0",
        "dscqty": 0,
        "prd": "CNC",
        "prctyp": "MKT",
        "mkt_protection": "0",
        "ret": "DAY",
        "remarks": "",
        "ordersource": "Web",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ext_remarks": "External remarks",
        "cl_ord_id": "",
        "tsym2": "",
        "trantype2": "",
        "qty2": "0",
        "prc2": "0",
        "tsym3": "0",
        "trantype3": "",
        "qty3": "0",
        "prc3": "0",
        "algo_id": "0",
        "naic_code": "0",
        "snonum": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0"
      }
    },
    {
      "endpoint": "ActivityOrderBook",
      "description": "Confirm futures leg traded.",
      "activity": "OrderStatusHandler",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },
    {
      "endpoint": "GetSecurityInfo",
      "description": "Extract NFO call option leg security info.",
      "activity": "ExtractSecurityInfo",
      "payload": {
        "exch": "NFO",
        "token": "46002"
      }
    },
    {
      "endpoint": "GetOrderMargin",
      "description": "Fetch margin for option short leg (hedge margin expected lower).",
      "activity": "ExtractGetOrderMargin",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "NFO",
        "tsym": "{{tsym}}",
        "qty": "{{lotsize}}",
        "trantype": "Sell",
        "ordno": "0",
        "prc": 0,
        "trgprc": "0",
        "dscqty": "0",
        "prd": "MIS",
        "prctyp": "Limit",
        "ordersource": "Web",
        "blprc": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0",
        "snonum": "0"
      }
    },
    {
      "endpoint": "PlaceOrder",
      "description": "Place MIS Sell for call option hedge leg.",
      "activity": "ExtractClientOrdId",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "NFO",
        "trantype": "Sell",
        "norenordno": "0",
        "segment": "DER",
        "tsym": "{{tsym}}",
        "qty": "{{lotsize}}",
        "prc": "{{lp}}",
        "trgprc": "0",
        "dscqty": 0,
        "prd": "MIS",
        "prctyp": "Limit",
        "mkt_protection": "0",
        "ret": "DAY",
        "remarks": "",
        "ordersource": "Web",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ext_remarks": "External remarks",
        "cl_ord_id": "",
        "tsym2": "",
        "trantype2": "",
        "qty2": "0",
        "prc2": "0",
        "tsym3": "0",
        "trantype3": "",
        "qty3": "0",
        "prc3": "0",
        "algo_id": "0",
        "naic_code": "0",
        "snonum": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0"
      }
    },
    {
      "endpoint": "ActivityOrderBook",
      "activity": "OrderStatusHandler",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },
    {
      "endpoint": "TradeBook",
      "activity": "ExtractTradeFill",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}",
        "prd": ""
      }
    },
    {
      "endpoint": "PositionBook",
      "description": "Validate both hedge legs are in position book.",
      "activity": "ValidatePostPositions",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}",
        "prd": ""
      }
    },
    {
      "endpoint": "Limits",
      "description": "Validate reduced hedge margin applied.",
      "activity": "ExtractPostLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    }
  ]
}