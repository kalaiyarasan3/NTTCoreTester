{
  "testName": "Futures MIS Buy - NFO",
  "description": "Place MIS Buy order on NFO futures (DER segment), validate intraday margin block and position creation.",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "GetSecurityInfo",
      "description": "Extract security info for NFO futures token.",
      "activity": "ExtractSecurityInfo",
      "payload": { "exch": "NFO", "token": "35004" }
    },
    {
      "endpoint": "Limits",
      "activity": "ExtractPreLimitMargin",
      "payload": { "actid": "{{uid}}", "uid": "{{uid}}" }
    },
    {
      "endpoint": "GetOrderMargin",
      "description": "Fetch MIS margin for NFO futures Buy.",
      "activity": "ExtractGetOrderMargin",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "tsym": "{{tsym}}",
        "qty": "1",
        "trantype": "Buy",
        "ordno": "0",
        "prc": 0,
        "trgprc": "0",
        "dscqty": "0",
        "prd": "MIS",
        "prctyp": "Limit",
        "ordersource": "Web",
        "blprc": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0",
        "snonum": "0"
      }
    },
    {
      "endpoint": "PositionBook",
      "activity": "ExtractPrePositions",
      "payload": { "actid": "{{uid}}", "uid": "{{uid}}", "prd": "" }
    },
    {
      "endpoint": "PlaceOrder",
      "description": "Place NFO Futures MIS Buy Market order.",
      "activity": "ExtractClientOrdId",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "trantype": "Buy",
        "norenordno": "0",
        "segment": "DER",
        "tsym": "{{tsym}}",
        "qty": "{{lotsize}}",
        "prc": "0.00",
        "trgprc": "0",
        "dscqty": 0,
        "prd": "MIS",
        "prctyp": "MKT",
        "mkt_protection": "0",
        "ret": "DAY",
        "remarks": "",
        "ordersource": "Web",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ext_remarks": "External remarks",
        "cl_ord_id": "",
        "tsym2": "",
        "trantype2": "",
        "qty2": "0",
        "prc2": "0",
        "tsym3": "0",
        "trantype3": "",
        "qty3": "0",
        "prc3": "0",
        "algo_id": "0",
        "naic_code": "0",
        "snonum": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0"
      }
    },
    {
      "endpoint": "OrderBook",
      "activity": "SaveOrders",
      "payload": { "uid": "{{uid}}", "actid": "{{uid}}" }
    },
    {
      "endpoint": "ActivityOrderBook",
      "activity": "ValidateOrderBookSync",
      "payload": { "uid": "{{uid}}", "actid": "{{uid}}", "status": "ALL" }
    },
    {
      "endpoint": "ActivityOrderBook",
      "activity": "OrderStatusHandler",
      "payload": { "uid": "{{uid}}", "actid": "{{uid}}", "status": "ALL" }
    },
    {
      "endpoint": "TradeBook",
      "activity": "ExtractTradeFill",
      "payload": { "actid": "{{uid}}", "uid": "{{uid}}", "prd": "" }
    },
    {
      "endpoint": "PositionBook",
      "description": "Validate NFO futures long MIS position created.",
      "activity": "ValidatePostPositions",
      "payload": { "actid": "{{uid}}", "uid": "{{uid}}", "prd": "" }
    },
    {
      "endpoint": "Limits",
      "description": "Validate futures MIS margin blocked.",
      "activity": "ExtractPostLimitMargin",
      "payload": { "actid": "{{uid}}", "uid": "{{uid}}" }
    }
  ]
}
