{
  "testName": "Equity MIS Buy - NSE",
  "description": "Place MIS Buy order on NSE equity, validate intraday margin block and position creation.",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "GetSecurityInfo",
      "description": "Extract security info for NSE equity token.",
      "activity": "ExtractSecurityInfo",
      "payload": { "exch": "NSE", "token": "10604" }
    },
    {
      "endpoint": "Limits",
      "description": "Capture pre-order margin snapshot.",
      "activity": "ExtractPreLimitMargin",
      "payload": { "actid": "{{uid}}", "uid": "{{uid}}" }
    },
    {
      "endpoint": "GetOrderMargin",
      "description": "Fetch required margin for MIS Buy order.",
      "activity": "ExtractGetOrderMargin",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "tsym": "{{tsym}}",
        "qty": "100",
        "trantype": "Buy",
        "ordno": "0",
        "prc": 0,
        "trgprc": "0",
        "dscqty": "0",
        "prd": "MIS",
        "prctyp": "Limit",
        "ordersource": "Web",
        "blprc": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0",
        "snonum": "0"
      }
    },
    {
      "endpoint": "PositionBook",
      "description": "Extract pre-trade positions.",
      "activity": "ExtractPrePositions",
      "payload": { "actid": "{{uid}}", "uid": "{{uid}}", "prd": "" }
    },
    {
      "endpoint": "PlaceOrder",
      "description": "Place MIS Buy Market order on NSE equity.",
      "activity": "ExtractClientOrdId",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "trantype": "Buy",
        "norenordno": "0",
        "segment": "EQ",
        "tsym": "{{tsym}}",
        "qty": 100,
        "prc": "0.00",
        "trgprc": "0",
        "dscqty": 0,
        "prd": "MIS",
        "prctyp": "MKT",
        "mkt_protection": "0",
        "ret": "DAY",
        "remarks": "",
        "ordersource": "Web",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ext_remarks": "External remarks",
        "cl_ord_id": "",
        "tsym2": "",
        "trantype2": "",
        "qty2": "0",
        "prc2": "0",
        "tsym3": "0",
        "trantype3": "",
        "qty3": "0",
        "prc3": "0",
        "algo_id": "0",
        "naic_code": "0",
        "snonum": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0"
      }
    },
    {
      "endpoint": "OrderBook",
      "description": "Save order for tracking.",
      "activity": "SaveOrders",
      "payload": { "uid": "{{uid}}", "actid": "{{uid}}" }
    },
    {
      "endpoint": "ActivityOrderBook",
      "description": "Validate order book sync timing.",
      "activity": "ValidateOrderBookSync",
      "payload": { "uid": "{{uid}}", "actid": "{{uid}}", "status": "ALL" }
    },
    {
      "endpoint": "ActivityOrderBook",
      "description": "Confirm order traded status.",
      "activity": "OrderStatusHandler",
      "payload": { "uid": "{{uid}}", "actid": "{{uid}}", "status": "ALL" }
    },
    {
      "endpoint": "TradeBook",
      "description": "Extract trade fill details.",
      "activity": "ExtractTradeFill",
      "payload": { "actid": "{{uid}}", "uid": "{{uid}}", "prd": "" }
    },
    {
      "endpoint": "PositionBook",
      "description": "Validate MIS position creation.",
      "activity": "ValidatePostPositions",
      "payload": { "actid": "{{uid}}", "uid": "{{uid}}", "prd": "" }
    },
    {
      "endpoint": "Limits",
      "description": "Validate intraday margin blocked after MIS Buy.",
      "activity": "ExtractPostLimitMargin",
      "payload": { "actid": "{{uid}}", "uid": "{{uid}}" }
    }
  ]
}
