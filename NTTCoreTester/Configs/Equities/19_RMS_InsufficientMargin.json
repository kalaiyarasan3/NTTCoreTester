{
  "testName": "RMS Rejection - Insufficient Margin",
  "description": "Place oversized NFO futures order to exceed available margin. Validate ORDER_REJECTED status and margin unchanged.",
  "stopOnFailure":false,
  "requests":
  [
    {
      "endpoint": "GetSecurityInfo",
      "activity": "ExtractSecurityInfo",
      "payload": {
        "exch": "NFO",
        "token": "35004"
      }
    },
    {
      "endpoint": "Limits",
      "activity": "ExtractPreLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },
    {
      "endpoint": "GetOrderMargin",
      "description": "Fetch margin for oversized order.",
      "activity": "ExtractGetOrderMargin",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "NFO",
        "tsym": "{{tsym}}",
        "qty": "9999",
        "trantype": "Buy",
        "ordno": "0",
        "prc": 0,
        "trgprc": "0",
        "dscqty": "0",
        "prd": "CNC",
        "prctyp": "Limit",
        "ordersource": "Web",
        "blprc": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0",
        "snonum": "0"
      }
    },
    {
      "endpoint": "PlaceOrder",
      "description": "Place oversized CNC Buy - expected RMS rejection.",
      "activity": "ExtractClientOrdId",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "NFO",
        "trantype": "Buy",
        "norenordno": "0",
        "segment": "DER",
        "tsym": "{{tsym}}",
        "qty": 9999,
        "prc": "{{lp}}",
        "trgprc": "0",
        "dscqty": 0,
        "prd": "CNC",
        "prctyp": "Limit",
        "mkt_protection": "0",
        "ret": "DAY",
        "remarks": "",
        "ordersource": "Web",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ext_remarks": "External remarks",
        "cl_ord_id": "",
        "tsym2": "",
        "trantype2": "",
        "qty2": "0",
        "prc2": "0",
        "tsym3": "0",
        "trantype3": "",
        "qty3": "0",
        "prc3": "0",
        "algo_id": "0",
        "naic_code": "0",
        "snonum": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0"
      }
    },
    {
      "endpoint": "ActivityOrderBook",
      "description": "Validate order is in ORDER_REJECTED status.",
      "activity": "OrderStatusHandler",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },
    {
      "endpoint": "Limits",
      "description": "Validate margin unchanged after rejection.",
      "activity": "ExtractPostLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    }
  ]
}