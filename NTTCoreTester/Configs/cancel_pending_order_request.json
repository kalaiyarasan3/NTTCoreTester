{
  "suiteName": "CancelPendingOrderMarginRelease",
  "description": "Validate margin block for pending order and release after cancel",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "GetSecurityInfo",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractSecurityInfo",
      "payload": {
        "exch": "NSE",
        "token": "13501"
      }
    },
    {
      "endpoint": "Limits",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractPreLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },
    {
      "endpoint": "GetOrderMargin",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "RMS"
      },
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "tsym": "{{tsym}}",
        "qty": "1",
        "trantype": "Buy",
        "ordno": "0",
        "prc": "{{lp}}",
        "trgprc": "0",
        "dscqty": "0",
        "prd": "CNC",
        "prctyp": "Limit",
        "ordersource": "Web",
        "blprc": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0",
        "snonum": "0"
      },
      "activity": "ExtractGetOrderMargin"
    },
    {
      "endpoint": "PlaceOrder",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractClientOrdId",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "trantype": "Buy",
        "segment": "EQ",
        "tsym": "{{tsym}}",
        "qty": 1,
        "prc": "7",
        "trgprc": "0",
        "dscqty": 0,
        "prd": "CNC",
        "prctyp": "Limit",
        "ret": "DAY",
        "ordersource": "Web"
      }
    },

    {
      "endpoint": "ActivityOrderBook",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "RMS"
      },
      "activity": "OrderStatusHandler",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },

    {
      "endpoint": "Limits",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractPostLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },

    {
      "endpoint": "CancelOrder",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "cl_ord_id": "{{cl_ord_id}}",
        "ordno": "{{cl_ord_id}}",
        "ext_remarks": "remarks"
      }
    },

    {
      "endpoint": "ActivityOrderBook",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "RMS"
      },
      "activity": "OrderStatusHandler",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },

    {
      "endpoint": "Limits",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractPostLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    }

  ]
}