{
  "suiteName": "CancelPendingOrderMarginRelease",
  "description": "(AMO)Validate margin block for pending order and release after cancel",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "GetSecurityInfo",
      "description": "Extracting Security Info for placing order and also to get lot size for calculating qty.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractSecurityInfo",
      "payload": {
        "exch": "NSE",
        "token": "13501"
      }
    },
    {
      "endpoint": "Limits",
      "description": "Extracting Limits to check the margin release and block before placing order.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractPreLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },
    {
      "endpoint": "GetOrderMargin",
      "description": "Extracting Order Margin for placing order and also to get margin details for calculating available margin after placing order.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "RMS"
      },
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "tsym": "{{tsym}}",
        "qty": "1",
        "trantype": "Buy",
        "ordno": "0",
        "prc": "{{lp}}",
        "trgprc": "0",
        "dscqty": "0",
        "prd": "CNC",
        "prctyp": "Limit",
        "ordersource": "Web",
        "blprc": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0",
        "snonum": "0"
      },
      "activity": "ExtractGetOrderMargin"
    },
    {
      "endpoint": "PlaceOrder",
      "description": "Placing AMO Buy order with limit price which is below the current market price to make sure the order goes to pending state and also to check the margin block for pending order.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractClientOrdId",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "trantype": "Buy",
        "segment": "EQ",
        "tsym": "{{tsym}}",
        "qty": 1,
        "prc": "7",
        "trgprc": "0",
        "dscqty": 0,
        "prd": "CNC",
        "prctyp": "Limit",
        "ret": "DAY",
        "ordersource": "Web"
      }
    },

    {
      "endpoint": "ActivityOrderBook",
      "description": "Extracting order book to check the order is in pending state and also to extract the order number for canceling the order.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "RMS"
      },
      "activity": "OrderStatusHandler",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },

    {
      "endpoint": "Limits",
      "description": "Extracting Limits to check the margin block for pending order after placing order.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractPostLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },
    {
      "endpoint": "OrderBook",
      "description": "Extracting Order Book to get order details using cl_ord_id.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService"
      },
      "activity": "SaveOrders",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}"
      }
    },
    {
      "endpoint": "ActivityOrderBook",
      "description": "Validating Order Book Sync activity to check whether order book is syncing properly or not and also checking the time difference between placeOrder to ActivityBook",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService"
      },
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      },
      "activity": "ValidateOrderBookSync"
    },

    {
      "endpoint": "CancelOrder",
      "description": "Canceling the pending order and also to check the margin release after canceling the pending order.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "cl_ord_id": "{{cl_ord_id}}",
        "ordno": "{{cl_ord_id}}",
        "ext_remarks": "remarks"
      }
    },

    {
      "endpoint": "ActivityOrderBook",
      "description": "Extracting order book to check the order is canceled successfully and also to check the margin release after canceling the pending order.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "RMS"
      },
      "activity": "OrderStatusHandler",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      }
    },

    {
      "endpoint": "Limits",
      "description": "Extracting Limits to check the margin release after canceling the pending order.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractPostLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    }

  ]
}