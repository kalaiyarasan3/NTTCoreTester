{
  "suiteName": "Pledge",
  "description": "Validate pledge and unpledge integrity",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "Holdings",
      "description": "Fetch holdings and extract a symbol to place a pledge order (uses current holding symbol)",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      },
      "activity": "ExtractPledgeSymbol"
    },
    {
      "endpoint": "CreatePledgeHoldings",
      "description": "Create a pledge request for the selected symbol and quantity",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "payload": {
        "DealerUCC": "{{uid}}",
        "ClientUCC": "{{uid}}",
        "SymbolData": [
          {
            "Quantity": 5,
            "SymbolName": "{{PledgeOrderSymbol}}",
            "HoldingExchange": "NSE",
            "Exchange": "ALL",
            "Segment": "ALL",
            "Product": "MTF"
          }
        ]
      }
    },

    {
      "endpoint": "Holdings",
      "description": "Verify that the pledged quantity is updated correctly",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      },
      "activity": "ValidatePledgeIntegrity"
    },

    {
      "endpoint": "CreateUnpledgeHoldings",
      "description": "Create an unpledge request for the selected symbol with maximum quantity",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "payload": {
        "DealerUCC": "{{uid}}",
        "ClientUCC": "{{uid}}",
        "SymbolData": [
          {
            "Quantity": "1",
            "SymbolName": "{{PledgeOrderSymbol}}",
            "HoldingExchange": "NSE",
            "Exchange": "ALL",
            "Segment": "ALL",
            "Product": "MTF"
          }
        ]
      }
    },
    {
      "endpoint": "Holdings",
      "description": "Verify that the unpledged quantity is updated correctly",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      },
      "activity": "ValidatePledgeIntegrity"
    },
    {
      "endpoint": "CreateUnpledgeHoldings",
      "description": "Send a duplicate unpledge request to test system validation",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "payload": {
        "DealerUCC": "{{uid}}",
        "ClientUCC": "{{uid}}",
        "SymbolData": [
          {
            "Quantity": 1,
            "SymbolName": "{{PledgeOrderSymbol}}",
            "HoldingExchange": "NSE",
            "Exchange": "ALL",
            "Segment": "ALL",
            "Product": "MTF"
          }
        ]
      }
    },
    {
      "endpoint": "Holdings",
      "description": "Verify that the duplicate unpledge request is handled correctly",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      },
      "activity": "ValidatePledgeIntegrity"
    }

  ]
}