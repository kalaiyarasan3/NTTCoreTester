{
  "suiteName": "Login Auth",
  "description": "Checkin Login, Check Login endpoints and stores Auth Token",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "Login",
      "description": "Authenticate user and generate session token",
      "headers": {},
      "activity": "ExtractSession",
      "payload": {
        "uid": "47054457",
        "pwd": "Navia@123",
        "otp": "7657768",
        "TwoFA": 1
      }
    },
    {
      "endpoint": "CheckLogin",
      "description": "Verify that session token is valid",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService"
      },
      "activity": "",
      "payload": {}
    },
    {
      "endpoint": "GetClientBankInfo",
      "description": "Fetch bank details linked to client account",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}"
      }
    }
  ]
}