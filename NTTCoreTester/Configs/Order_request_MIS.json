{
  "suiteName": "Order ",
  "description": "Place Order (Sell)",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "PositionBook",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractPrePositions",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}",
        "prd": ""
      }
    },
    {
      "endpoint": "Limits",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractPreLimitMargin",
      "payload": {
        "actid": "{{uid}}",
        "uid": "{{uid}}"
      }
    },
    {
      "endpoint": "GetSecurityInfo",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractSecurityInfo",
      "payload": {
        "exch": "NSE",
        "token": "10604"
      }
    },
    {
      "endpoint": "GetOrderMargin",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "RMS"
      },
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "tsym": "{{tsym}}",
        "qty": "100",
        "trantype": "Sell",
        "ordno": "0",
        "prc": "{{lp}}",
        "trgprc": "0",
        "dscqty": "0",
        "prd": "MIS",
        "prctyp": "Limit",
        "ordersource": "Web",
        "blprc": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0",
        "snonum": "0"
      },
      "activity": "ExtractGetOrderMargin"
    },
    {
      "endpoint": "PlaceOrder",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractClientOrdId",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "exch": "{{exch}}",
        "trantype": "Sell",
        "norenordno": "0",
        "segment": "EQ",
        "tsym": "{{tsym}}",
        "qty": 10,
        "prc": "{{lp}}",
        "trgprc": "0",
        "dscqty": 0,
        "prd": "MIS",
        "prctyp": "Limit",
        "mkt_protection": "0",
        "ret": "DAY",
        "remarks": "",
        "ordersource": "Web",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ext_remarks": "External remarks",
        "cl_ord_id": "",
        "tsym2": "",
        "trantype2": "",
        "qty2": "0",
        "prc2": "0",
        "tsym3": "0",
        "trantype3": "",
        "qty3": "0",
        "prc3": "0",
        "algo_id": "0",
        "naic_code": "0",
        "snonum": "0",
        "filshares": "0",
        "rorgqty": "0",
        "orgtrgprc": "0"
      }
    },
    {
      "endpoint": "OrderBook",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "SaveOrders",
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}"
      }
    },
    {
      "endpoint": "ActivityOrderBook",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "RMS"
      },
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      },
      "activity": "ValidateOrderBookSync"
    },
    {
      "endpoint": "ActivityOrderBook",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "RMS"
      },
      "payload": {
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "status": "ALL"
      },
      "activity": "GetLastOrderStatus"
    },
    {
      "endpoint": "ModifyOrder",
      "method": "POST",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService",
        "Source": "WEB"
      },
      "activity": "ExtractClientOrdId",
      "payload": {
        "exch": "{{exch}}",
        "ordno": "{{ordno}}",
        "prctyp": "MKT",
        "prc": "{{lp}}",
        "qty": 15,
        "tsym": "{{tsym}}",
        "ret": "",
        "mkt_protection": "0",
        "trgprc": "0.00",
        "dscqty": 0,
        "ext_remarks": "",
        "cl_ord_id": "{{cl_ord_id}}",
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ordersource": "Web",
        "orderactivity": 1,
        "prd": "MIS",
        "tqty": 50
      }
    }

  ]
}


