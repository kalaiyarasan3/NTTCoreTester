{
  "suiteName": "Order Request MIS",
  "description": "Place Order (Sell) and checking positions are updated and margin checking",
  "stopOnFailure": true,
  "requests": [
    {
      "endpoint": "ModifyOrder",
      "description": "Modifying the same order to MKT order type and also changing the qty to 15 to check whether modification is working or not for MIS product type.",
      "headers": {
        "AuthToken": "{{token}}",
        "Module": "OrderService"
      },
      "activity": "ExtractClientOrdId",
      "payload": {
        "exch": "{{exch}}",
        "ordno": "{{ordno}}",
        "prctyp": "MKT",
        "prc": "{{lp}}",
        "qty": 15,
        "tsym": "{{tsym}}",
        "ret": "",
        "mkt_protection": "0",
        "trgprc": "0.00",
        "dscqty": 0,
        "ext_remarks": "",
        "cl_ord_id": "{{cl_ord_id}}",
        "uid": "{{uid}}",
        "actid": "{{uid}}",
        "bpprc": "0",
        "blprc": "0",
        "trailprc": "0",
        "ordersource": "Web",
        "orderactivity": 1,
        "prd": "MIS",
        "tqty": 50
      }
    }

  ]
}


